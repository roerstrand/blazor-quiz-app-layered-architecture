@rendermode InteractiveServer
@implements IDisposable

@inject NavigationManager NavigationManager
@inject JwtTokenStore TokenStore
@inject JwtAuthStateProvider AuthStateProvider

<div class="sidebar-brand">
    <div class="brand-logo-sm"><span class="brand-hack">Hack</span><span class="brand-proof">Proof</span></div>
</div>

<div class="nav-section">
    <AuthorizeView>
        <Authorized>
            <div class="nav-label">Menu</div>
            <nav class="nav flex-column px-2">
                <NavLink class="nav-link" href="/categories">
                    <span class="nav-icon">📚</span> Categories
                </NavLink>
                <NavLink class="nav-link" href="/profile">
                    <span class="nav-icon">👤</span> Profile
                </NavLink>
            </nav>
        </Authorized>
        <NotAuthorized>
            <div class="nav-label">Account</div>
            <nav class="nav flex-column px-2">
                <NavLink class="nav-link" href="/Account/Login">
                    <span class="nav-icon">🔑</span> Log in
                </NavLink>
                <NavLink class="nav-link" href="/Account/Register">
                    <span class="nav-icon">✚</span> Register
                </NavLink>
            </nav>
        </NotAuthorized>
    </AuthorizeView>
</div>

<div class="sidebar-footer">
    <AuthorizeView>
        <Authorized>
            <div class="sidebar-user">
                <div class="sidebar-user-avatar">@(context.User.Identity?.Name?.Substring(0,1).ToUpper())</div>
                <span class="sidebar-user-name">@context.User.Identity?.Name</span>
            </div>
            <button class="nav-link nav-logout-btn" @onclick="Logout">
                <span class="nav-icon">🚪</span> Log out
            </button>
        </Authorized>
    </AuthorizeView>
</div>

@code {
    private void Logout()
    {
        TokenStore.Clear();
        AuthStateProvider.NotifyAuthStateChanged();
        NavigationManager.NavigateTo("/");
    }

    public void Dispose() { }
}
