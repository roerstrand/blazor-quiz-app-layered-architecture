@page "/categories"
@using Cyberquiz.Shared.DTOs
@using Cyberquiz.UI.Components.Pages.Components
@using Cyberquiz.UI.Services
@inject NavigationManager Nav
@inject ApiService ApiService

<h3>Categories</h3>

<h2>Välj en kategori</h2>

@if (_categories is null)
{
    <p>Laddar...</p>
}
else if (_categories.Count == 0)
{
    <p>Inga kategorier hittades.</p>
}
else
{
    @foreach (var c in _categories)
    {
        <div class="card p-3 mb-3">
            <h4>@c.Name</h4>
            <p>Avklarade subkategorier: <strong>@c.CompletedSubCategories</strong> / @c.TotalSubCategories</p>

            <ul>
                @foreach (var s in c.SubCategories.OrderBy(x => x.Order))
                {
                    <li style="margin-bottom:8px;">
                        <span>@(s.IsLocked ? "🔒" : "🔓")</span>
                        <strong style="margin-left:6px;">@s.Name</strong>

                        @if (s.IsCompleted)
                        {
                            <span style="margin-left:6px;">✅</span>
                        }

                        <button class="btn btn-sm btn-secondary"
                                style="margin-left:10px;"
                                @onclick="() => GoToSubCategories(c.Id)">
                            Visa subkategorier
                        </button>
                    </li>
                }
            </ul>
        </div>
    }
}

@code {
    private List<CategoryDto>? _categories;

    protected override async Task OnInitializedAsync()
    {
        _categories = await ApiService.GetCategoryOverviewAsync(); 
    }
    private void GoToSubCategories(int categoryId)
    {
        Nav.NavigateTo($"/categories/{categoryId}/subcategories");
    }
}