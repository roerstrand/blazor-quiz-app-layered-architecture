@page "/categories"
@using Cyberquiz.Shared.DTOs
@using Cyberquiz.UI.Components.Pages.Components
@using Cyberquiz.UI.Services
@inject NavigationManager Nav
@inject ApiService ApiService
@rendermode InteractiveServer

<h3>Kategorier</h3>

@if (_categories is null)
{
    <p>Laddar...</p>
}
else if (_categories.Count == 0)
{
    <p>Inga kategorier hittades.</p>
}
else
{
    @foreach (var c in _categories)
    {
        <div class="card p-3 mb-3">
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <div>
                    <h4 style="margin:0;">@c.Name</h4>
                    <div style="opacity:.8;">
                        Avklarade: <strong>@c.CompletedSubCategories</strong> / @c.TotalSubCategories
                    </div>
                </div>

                <button type="button"
                        class="btn btn-sm btn-secondary"
                        @onclick="() => GoToSubCategories(c.Id)">
                    Alla subkategorier
                </button>
            </div>

            <hr />

            @if (c.SubCategories is null || c.SubCategories.Count == 0)
            {
                <p style="opacity:.8;">Inga subkategorier.</p>
            }
            else
            {
                <div class="sub-grid">
                    @foreach (var s in c.SubCategories.OrderBy(x => x.Order))
                    {
                        <div class="sub-card @(s.IsLocked ? "locked" : "unlocked")"
                             @onclick="() => OpenSubCategory(s)">
                            <div style="display:flex; justify-content:space-between; align-items:center;">
                                <div>
                                    <div style="font-weight:700;">
                                        @(s.IsLocked ? "🔒" : "🔓") @s.Name
                                        @if (s.IsCompleted)
                                        {
                                            <span> ✅</span>
                                        }
                                    </div>
                                    <div style="opacity:.75; font-size:0.9rem;">
                                        Nivå: @s.Order • Frågor: @s.QuestionCount
                                    </div>
                                </div>

                                <span style="opacity:.7;">➡️</span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(s.Description))
                            {
                                <div style="margin-top:8px; opacity:.85; font-size:0.95rem;">
                                    @s.Description
                                </div>
                            }

                            @if (s.IsLocked)
                            {
                                <div style="margin-top:8px; color:#b91c1c; font-size:0.9rem;">
                                    Låst – klara föregående nivå med minst 80% för att låsa upp.
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
}

<style>
    .sub-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
    }

    .sub-card {
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        padding: 12px 14px;
        background: white;
        cursor: pointer;
        transition: transform .05s, border-color .15s;
    }

        .sub-card:hover {
            border-color: #7c3aed;
            transform: translateY(-1px);
        }

        .sub-card.locked {
            opacity: .85;
            cursor: not-allowed;
        }
</style>

@code {
    private List<CategoryDto>? _categories;

    protected override async Task OnInitializedAsync()
    {
        _categories = await ApiService.GetCategoriesAsync();
    }

    private void GoToSubCategories(int categoryId)
        => Nav.NavigateTo($"/categories/{categoryId}/subcategories");

    private void OpenSubCategory(SubCategoryDto s) //ta bort?
    {
        if (s.IsLocked) return;

        //starta quiz direkt:
        Nav.NavigateTo($"/quiz/{s.Id}");

        // Alternativ: gå till subcategories-sidan istället:
        // Nav.NavigateTo($"/categories/{}/subcategories");
    }
}