@page "/categories"
@using Cyberquiz.Shared.DTOs
@using Microsoft.AspNetCore.Authorization
@inject NavigationManager Nav
@inject ApiService ApiService
@rendermode InteractiveServer
@attribute [Authorize]

<div class="page-header">
    <h1>Categories</h1>
    <p class="text-muted">Choose a category and start training your cybersecurity skills.</p>
</div>

@if (_categories is null)
{
    <div class="d-flex align-items-center gap-2 text-muted">
        <div class="spinner-border spinner-border-sm"></div>
        <span>Loading...</span>
    </div>
}
else if (_categories.Count == 0)
{
    <div class="alert alert-info">No categories found.</div>
}
else
{
    @for (int i = 0; i < _categories.Count; i++)
    {
        var c = _categories[i];
        var pct = c.TotalSubCategories > 0
            ? (int)((double)c.CompletedSubCategories / c.TotalSubCategories * 100)
            : 0;
        var catId = c.Id;
        var color = _catColors[i % _catColors.Length];

        <div class="category-card" style="--cat:@color">
            <div class="category-card-header">
                <div>
                    <h3>@c.Name</h3>
                    <small class="cat-sub-label">@c.CompletedSubCategories of @c.TotalSubCategories modules complete</small>
                </div>
                <button class="btn cat-cta" @onclick="() => GoToSubs(catId)">
                    View modules →
                </button>
            </div>

            <div class="category-card-body">
                <div class="cat-progress-row">
                    <div class="cat-progress-track">
                        <div class="cat-progress-fill" style="width:@(pct)%"></div>
                    </div>
                    <span class="cat-progress-pct">@pct%</span>
                </div>

                @if (c.SubCategories is { Count: > 0 })
                {
                    <div class="sub-grid">
                        @foreach (var s in c.SubCategories.OrderBy(x => x.Order))
                        {
                            <div class="sub-card @(s.IsLocked ? "locked" : "unlocked")">
                                <div class="sub-card-title">
                                    @(s.IsLocked ? "🔒" : s.IsCompleted ? "✅" : "🔓") @s.Name
                                </div>
                                <div class="sub-card-meta">
                                    <span>Level @s.Order</span>
                                    <span>@s.QuestionCount questions</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    private List<CategoryDto>? _categories;

    private static readonly string[] _catColors =
        ["#1d4ed8", "#0f766e", "#7c3aed", "#b45309", "#be123c", "#0e7490"];

    protected override async Task OnInitializedAsync()
    {
        _categories = await ApiService.GetCategoriesAsync();
    }

    private void GoToSubs(int id) => Nav.NavigateTo($"/categories/{id}/subcategories");
}
