@page "/profile"
@using System.ComponentModel.DataAnnotations
@using Cyberquiz.UI.Components.Account
@using Cyberquiz.UI.Data
@using Cyberquiz.UI.Services
@using Cyberquiz.Shared.DTOs
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject ApiService ApiService
@inject ILogger<Profile> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

@attribute [Authorize]


<h1>Profile</h1>

<div class="row">
    <div class="col-lg-6">
        <section class="mb-4">
            <StatusMessage Message="@successMessage" />
            <h2>Welcome, @currentUsername</h2>
            <p class="text-muted">Member since: @memberSince?.ToString("yyyy-MM-dd")</p>
            <hr />
        </section>

        <section>
            <StatusMessage Message="@errorMessage" />
            <EditForm Model="UsernameInput" method="post" OnValidSubmit="OnValidSubmitUsernameAsync" FormName="change-username">
                <DataAnnotationsValidator />
                <h2>Change your username</h2>
                <hr />
                <ValidationSummary class="text-danger" role="alert" />
                
                <div class="form-floating mb-3">
                    <input type="text" value="@currentUsername" id="current-username" class="form-control" placeholder="Current username" disabled />
                    <label for="current-username" class="form-label">Current username</label>
                </div>
                
                <div class="form-floating mb-3">
                    <InputText @bind-Value="UsernameInput.NewUsername" id="UsernameInput.NewUsername" class="form-control" autocomplete="username" aria-required="true" placeholder="New username" />
                    <label for="UsernameInput.NewUsername" class="form-label">New username</label>
                    <ValidationMessage For="() => UsernameInput.NewUsername" class="text-danger" />
                </div>
                
                <div>
                    <button type="submit" class="w-100 btn btn-lg btn-primary" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Update username
                    </button>
                </div>
            </EditForm>
        </section>

        <hr class="my-4" />

        <section>
            <EditForm Model="PasswordInput" method="post" OnValidSubmit="OnValidSubmitPasswordAsync" FormName="change-password">
                <DataAnnotationsValidator />
                <h2>Change your password</h2>
                <hr />
                <ValidationSummary class="text-danger" role="alert" />

                <div class="form-floating mb-3">
                    <InputText type="password" @bind-Value="PasswordInput.CurrentPassword" id="PasswordInput.CurrentPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Current password" />
                    <label for="PasswordInput.CurrentPassword" class="form-label">Current password</label>
                    <ValidationMessage For="() => PasswordInput.CurrentPassword" class="text-danger" />
                </div>

                <div class="form-floating mb-3">
                    <InputText type="password" @bind-Value="PasswordInput.NewPassword" id="PasswordInput.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="New password" />
                    <label for="PasswordInput.NewPassword" class="form-label">New password</label>
                    <ValidationMessage For="() => PasswordInput.NewPassword" class="text-danger" />
                </div>

                <div class="form-floating mb-3">
                    <InputText type="password" @bind-Value="PasswordInput.ConfirmPassword" id="PasswordInput.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Confirm password" />
                    <label for="PasswordInput.ConfirmPassword" class="form-label">Confirm new password</label>
                    <ValidationMessage For="() => PasswordInput.ConfirmPassword" class="text-danger" />
                </div>

                <div>
                    <button type="submit" class="w-100 btn btn-lg btn-primary" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Update password
                    </button>
                </div>
            </EditForm>
        </section>
    </div>
@code {

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private UsernameInputModel UsernameInput { get; set; } = default!;

    [SupplyParameterFromForm]
    private PasswordInputModel PasswordInput { get; set; } = default!;

}
