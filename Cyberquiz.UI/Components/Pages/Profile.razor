@page "/profile"
@using System.ComponentModel.DataAnnotations
@using Cyberquiz.UI.Components.Account
@using Cyberquiz.UI.Components.Account.Shared
@using Cyberquiz.UI.Data
@using Cyberquiz.UI.Services
@using Cyberquiz.Shared.DTOs
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject ApiService ApiService
@inject ILogger<Profile> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

@attribute [Authorize]


<h1>Profil</h1>

<div class="row">
    <div class="col-lg-6">
        <section class="mb-4">
            <StatusMessage Message="@successMessage" />
            <h2>Välkommen, @currentUsername</h2>
            
            <hr />
        </section>

        <section>
            <StatusMessage Message="@errorMessage" />
            <EditForm Model="UsernameInput" method="post" OnValidSubmit="OnValidSubmitUsernameAsync" FormName="change-username">
                <DataAnnotationsValidator />
                <h2>Byt användarnamn</h2>
                <hr />
                <ValidationSummary class="text-danger" role="alert" />
                
                <div class="form-floating mb-3">
                    <input type="text" value="@currentUsername" id="current-username" class="form-control" placeholder="Nuvarande användarnamn" disabled />
                    <label for="current-username" class="form-label">Nuvarande användarnamn</label>
                </div>
                
                <div class="form-floating mb-3">
                    <InputText @bind-Value="UsernameInput.NewUsername" id="UsernameInput.NewUsername" class="form-control" autocomplete="username" aria-required="true" placeholder="Nytt användarnamn" />
                    <label for="UsernameInput.NewUsername" class="form-label">Nytt användarnamn</label>
                    <ValidationMessage For="() => UsernameInput.NewUsername" class="text-danger" />
                </div>
                
                <div>
                    <button type="submit" class="w-100 btn btn-lg btn-primary" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Uppdatera användarnamn
                    </button>
                </div>
            </EditForm>
        </section>

        <hr class="my-4" />

        <section>
            <EditForm Model="PasswordInput" method="post" OnValidSubmit="OnValidSubmitPasswordAsync" FormName="change-password">
                <DataAnnotationsValidator />
                <h2>Byt lösenord</h2>
                <hr />
                <ValidationSummary class="text-danger" role="alert" />

                <div class="form-floating mb-3">
                    <InputText type="password" @bind-Value="PasswordInput.CurrentPassword" id="PasswordInput.CurrentPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Nuvarande lösenord" />
                    <label for="PasswordInput.CurrentPassword" class="form-label">Nuvarande lösenord</label>
                    <ValidationMessage For="() => PasswordInput.CurrentPassword" class="text-danger" />
                </div>

                <div class="form-floating mb-3">
                    <InputText type="password" @bind-Value="PasswordInput.NewPassword" id="PasswordInput.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Nytt lösenord" />
                    <label for="PasswordInput.NewPassword" class="form-label">Nytt lösenord</label>
                    <ValidationMessage For="() => PasswordInput.NewPassword" class="text-danger" />
                </div>

                <div class="form-floating mb-3">
                    <InputText type="password" @bind-Value="PasswordInput.ConfirmPassword" id="PasswordInput.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Bekräfta nytt lösenord" />
                    <label for="PasswordInput.ConfirmPassword" class="form-label">Bekräfta nyttlösenord</label>
                    <ValidationMessage For="() => PasswordInput.ConfirmPassword" class="text-danger" />
                </div>

                <div>
                    <button type="submit" class="w-100 btn btn-lg btn-primary" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Uppdatera lösenord
                    </button>
                </div>
            </EditForm>
        </section>
    </div>
    <div class="col-lg-4 col-lg-offset-2">
        <section>
            <h3>Din progression</h3>
            <hr />

            @if (isLoading)
            {
                <div class="text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2">Loading your progress...</p>
                </div>
            }
            else if (categories != null && categories.Any())
            {
                @foreach (var category in categories)
                {
                    <div class="card mb-3">
                        <div class="card-body">
                            <h5 class="card-title">@category.Name</h5>
                            @if (!string.IsNullOrEmpty(category.Description))
                            {
                                <p class="card-text text-muted small">@category.Description</p>
                            }
                            <p class="card-text">
                                <strong>Progress:</strong> @category.CompletedSubCategories / @category.TotalSubCategories completed
                            </p>

                            @if (category.SubCategories != null && category.SubCategories.Any())
                            {
                                <ul class="list-unstyled mb-0">
                                    @foreach (var sub in category.SubCategories)
                                    {
                                        <li class="small">
                                            @if (sub.IsCompleted)
                                            {
                                                <span class="text-success">✓ @sub.Name</span>
                                            }
                                            else if (sub.IsLocked)
                                            {
                                                <span class="text-muted">🔒 @sub.Name</span>
                                            }
                                            else
                                            {
                                                <span class="text-warning">○ @sub.Name</span>
                                            }
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>
                }

                <div class="alert alert-info mt-3">
                    <strong>Total:</strong> @TotalCompleted klara, @TotalRemaining kvar
                </div>
            }
            else
            {
                <p class="text-muted">Ingen progression än. Starta ett quiz för att börja!</p>
                <p>
                    <a href="/categories" class="btn btn-primary">Gå till kategorier</a>
                </p>
            }
        </section>
    </div>
</div>
@code {
    private ApplicationUser? user;
    private string? currentUsername;
    private DateTime? memberSince;
    private bool isLoading = true;
    private bool isSaving = false;
    private string? successMessage;
    private string? errorMessage;
    private List<CategoryDto>? categories;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private UsernameInputModel UsernameInput { get; set; } = default!;

    [SupplyParameterFromForm]
    private PasswordInputModel PasswordInput { get; set; } = default!;

    private int TotalCompleted => categories?.Sum(c => c.CompletedSubCategories) ?? 0; //summerar completed subcats för alla kategorier
    private int TotalRemaining => categories?.Sum(c => c.TotalSubCategories - c.CompletedSubCategories) ?? 0; //summerar kvarstående subcats för alla kategorier

    protected override async Task OnInitializedAsync()
    {
        UsernameInput ??= new();
        PasswordInput ??= new();

        user = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectTo("/login");
            return;
        }

        currentUsername = await UserManager.GetUserNameAsync(user);

        await LoadProgressAsync();
    }
    private async Task LoadProgressAsync()
    {
        isLoading = true;
        try
        {
            categories = await ApiService.GetCategoriesAsync(currentUsername);
        }
        catch (Exception e)
        {
            errorMessage = "Failed to load progression data.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnValidSubmitUsernameAsync()
    {
        if (user is null || string.IsNullOrEmpty(UsernameInput.NewUsername))
            return;

        if (UsernameInput.NewUsername == currentUsername)
        {
            errorMessage = "The new username is the same as the current username.";
            return;
        }

        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var result = await UserManager.SetUserNameAsync(user, UsernameInput.NewUsername);

            if (result.Succeeded)
            {
                await SignInManager.RefreshSignInAsync(user);
                currentUsername = UsernameInput.NewUsername;
                UsernameInput.NewUsername = string.Empty;
                successMessage = "Your username has been updated.";
                Logger.LogInformation("User {UserName} changed their username.", currentUsername);
            }
            else
            {
                errorMessage = $"Error: {string.Join(", ", result.Errors.Select(e => e.Description))}";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating username");
            errorMessage = "An error occurred while updating your username.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task OnValidSubmitPasswordAsync()
    {
        if (user is null)
            return;

        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var result = await UserManager.ChangePasswordAsync(
            user,
            PasswordInput.CurrentPassword,
            PasswordInput.NewPassword);

            if (result.Succeeded)
            {
                await SignInManager.RefreshSignInAsync(user);
                PasswordInput = new();
                successMessage = "Your password has been changed.";
                Logger.LogInformation("User {UserName} changed their password.", currentUsername);
            }
            else
            {
                errorMessage = $"Error: {string.Join(", ", result.Errors.Select(e => e.Description))}";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error changing password");
            errorMessage = "An error occurred while changing your password.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private sealed class UsernameInputModel
    {
        [Required]
        [StringLength(50, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 3)]
        [Display(Name = "New username")]
        public string NewUsername { get; set; } = "";
    }

    private sealed class PasswordInputModel
    {
        [Required]
        [DataType(DataType.Password)]
        [Display(Name = "Current password")]
        public string CurrentPassword { get; set; } = "";

        [Required]
        [StringLength(100, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        [Display(Name = "New password")]
        public string NewPassword { get; set; } = "";

        [DataType(DataType.Password)]
        [Display(Name = "Confirm new password")]
        [Compare("NewPassword", ErrorMessage = "The new password and confirmation password do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
