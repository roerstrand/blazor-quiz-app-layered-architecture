@page "/profile"
@using System.ComponentModel.DataAnnotations
@using Cyberquiz.Shared.DTOs
@using Cyberquiz.Shared.DTOs.AI_DTOs
@using Microsoft.AspNetCore.Authorization
@inject ApiService ApiService
@inject AiCoachApiService AiCoachApiService
@inject JwtTokenStore TokenStore
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@rendermode InteractiveServer
@attribute [Authorize]

<div class="page-header">
    <h1>Profile</h1>
    <p>Logged in as <strong>@currentUsername</strong></p>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; max-width:1000px;">

    <!-- AI Coach -->
    <div class="card" style="grid-column:1/-1;">
        <div class="card-header d-flex align-items-center gap-2">
            <span>🤖</span> AI Coach
        </div>
        <div class="card-body">
            <p class="text-muted small mb-3">
                Our AI analyses your progress and provides personal feedback on your strengths and weaknesses.
            </p>

            <button class="btn btn-primary"
                    disabled="@(aiLoading || !aiActive)"
                    @onclick="AskAiCoach">
                @if (aiLoading)
                {
                    <span class="spinner-border spinner-border-sm"></span>
                    <span>Analysing...</span>
                }
                else if (!aiActive)
                {
                    <span>AI Coach unavailable</span>
                }
                else
                {
                    <span>Analyse my progress</span>
                }
            </button>

            @if (!string.IsNullOrWhiteSpace(aiError))
            {
                <div class="alert alert-danger mt-3">@aiError</div>
            }

            @if (aiFeedback != null && !string.IsNullOrWhiteSpace(aiFeedback.Feedback))
            {
                <div class="alert alert-info mt-3">
                    <strong>Feedback</strong>
                    <p class="mb-0 mt-1">@aiFeedback.Feedback</p>
                </div>
            }
        </div>
    </div>

    <!-- GDPR -->
    <div class="gdpr-card" style="grid-column:1/-1;">
        <div class="gdpr-card-left">
            <div class="gdpr-icon">⚖️</div>
            <div>
                <div class="gdpr-title">Right to be forgotten</div>
                <div class="gdpr-subtitle">Article 17, EU General Data Protection Regulation (GDPR)</div>
            </div>
        </div>
        <div class="gdpr-body">
            <p class="gdpr-desc">
                You have the right to request the deletion of your personal data. This includes all your quiz history,
                answers and progress linked to your account.
            </p>

            @if (!string.IsNullOrEmpty(deleteMessage))
            {
                <div class="alert @(deleteError ? "alert-danger" : "alert-success") py-2 mb-3">@deleteMessage</div>
            }

            <div class="gdpr-actions">
                <div class="gdpr-action-row">
                    <div>
                        <div class="gdpr-action-label">Clear old data</div>
                        <div class="gdpr-action-desc">Keeps your 3 most recent sessions and deletes the rest.</div>
                    </div>
                    <button class="btn btn-outline-secondary btn-sm"
                            disabled="@deleteLoading"
                            @onclick="KeepRecent">
                        @if (deleteLoading && deleteAction == "keep")
                        { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Clear old history
                    </button>
                </div>

                <hr class="gdpr-divider" />

                <div class="gdpr-action-row">
                    <div>
                        <div class="gdpr-action-label text-danger">Delete all my data</div>
                        <div class="gdpr-action-desc">All your progress and quiz history will be permanently deleted. This cannot be undone.</div>
                    </div>
                    @if (!confirmDeleteAll)
                    {
                        <button class="btn btn-danger btn-sm"
                                disabled="@deleteLoading"
                                @onclick="() => confirmDeleteAll = true">
                            Ta bort min data
                        </button>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-danger small fw-semibold">Confirm deletion</span>
                            <button class="btn btn-danger btn-sm"
                                    disabled="@deleteLoading"
                                    @onclick="DeleteAll">
                                @if (deleteLoading && deleteAction == "all")
                                { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Yes, delete everything
                            </button>
                            <button class="btn btn-outline-secondary btn-sm"
                                    @onclick="() => confirmDeleteAll = false">
                                Cancel
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Progression -->
    <div style="grid-column:1/-1;">
        <h2 class="mb-3">Your progress</h2>

        @if (isLoading)
        {
            <div class="d-flex align-items-center gap-2 text-muted">
                <span class="spinner-border spinner-border-sm"></span>
                <span>Loading progress...</span>
            </div>
        }
        else if (categories is { Count: > 0 })
        {
            <div class="profile-summary">
                <span>✅ <strong>@TotalCompleted</strong> complete</span>
                <span class="divider"></span>
                <span>⏳ <strong>@TotalRemaining</strong> remaining</span>
            </div>

            <div class="profile-progress-grid">
                @for (int i = 0; i < categories.Count; i++)
                {
                    var category = categories[i];
                    var pct = category.TotalSubCategories > 0
                        ? (int)((double)category.CompletedSubCategories / category.TotalSubCategories * 100)
                        : 0;
                    var color = _catColors[i % _catColors.Length];

                    <div class="profile-cat-card" style="--cat:@color">
                        <div class="profile-cat-header">
                            <span class="profile-cat-name">@category.Name</span>
                            <span class="profile-cat-pct">@pct%</span>
                        </div>
                        <div class="cat-progress-track" style="margin:.5rem 0 .85rem;">
                            <div class="cat-progress-fill" style="width:@(pct)%"></div>
                        </div>
                        <div class="profile-cat-meta">@category.CompletedSubCategories of @category.TotalSubCategories modules complete</div>

                        @if (category.SubCategories is { Count: > 0 })
                        {
                            <ul class="profile-sub-list">
                                @foreach (var sub in category.SubCategories)
                                {
                                    <li class="profile-sub-item @(sub.IsCompleted ? "done" : sub.IsLocked ? "locked" : "active")">
                                        @(sub.IsCompleted ? "✓" : sub.IsLocked ? "🔒" : "○") @sub.Name
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-body text-center" style="padding:2rem;">
                    <p class="text-muted mb-3">No progress yet. Start a quiz to begin!</p>
                    <a href="/categories" class="btn btn-primary">Go to categories</a>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private static readonly string[] _catColors =
        ["#1d4ed8", "#0f766e", "#7c3aed", "#b45309", "#be123c", "#0e7490"];

    private string? currentUsername;
    private bool isLoading = true;
    private List<CategoryDto>? categories;
    private bool aiLoading;
    private AiFeedbackDto? aiFeedback;
    private string? aiError;
    private bool aiActive = true;

    private bool deleteLoading;
    private bool confirmDeleteAll;
    private string? deleteMessage;
    private bool deleteError;
    private string? deleteAction;

    private int TotalCompleted => categories?.Sum(c => c.CompletedSubCategories) ?? 0;
    private int TotalRemaining => categories?.Sum(c => c.TotalSubCategories - c.CompletedSubCategories) ?? 0;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUsername = authState.User.Identity?.Name ?? TokenStore.Username;

        await LoadProgressAsync();
    }

    private async Task LoadProgressAsync()
    {
        isLoading = true;
        try { categories = await ApiService.GetCategoriesAsync(); }
        catch { }
        finally { isLoading = false; }
    }

    private async Task KeepRecent()
    {
        deleteLoading = true;
        deleteAction = "keep";
        deleteMessage = null;
        try
        {
            var ok = await ApiService.KeepRecentProgressAsync(3);
            deleteMessage = ok ? "The 3 most recent sessions were kept. The rest were deleted." : "Something went wrong.";
            deleteError = !ok;
            if (ok) await LoadProgressAsync();
        }
        catch { deleteMessage = "Unexpected error."; deleteError = true; }
        finally { deleteLoading = false; deleteAction = null; }
    }

    private async Task DeleteAll()
    {
        deleteLoading = true;
        deleteAction = "all";
        deleteMessage = null;
        confirmDeleteAll = false;
        try
        {
            var ok = await ApiService.DeleteAllProgressAsync();
            deleteMessage = ok ? "All progress has been deleted." : "Something went wrong.";
            deleteError = !ok;
            if (ok) await LoadProgressAsync();
        }
        catch { deleteMessage = "Unexpected error."; deleteError = true; }
        finally { deleteLoading = false; deleteAction = null; }
    }

    private async Task AskAiCoach()
    {
        aiLoading = true;
        aiError = null;
        aiFeedback = null;

        try
        {
            aiFeedback = await AiCoachApiService.GetFeedback();
            if (aiFeedback is null || string.IsNullOrWhiteSpace(aiFeedback.Feedback))
                aiError = "Could not get feedback from AI.";
        }
        catch (Exception ex)
        {
            aiError = $"Unexpected error: {ex.Message}";
            aiActive = false;
        }
        finally
        {
            aiLoading = false;
        }
    }
}
