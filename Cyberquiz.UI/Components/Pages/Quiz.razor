@page "/quiz/{SubCategoryId:int}"
@using Cyberquiz.Shared.DTOs
@using Cyberquiz.Shared.DTOs.Progress
@using Cyberquiz.UI.Components.Pages.Components
@using Cyberquiz.UI.Services
@inject ApiService ApiService


<h3>Quiz</h3>

<h3>Quiz</h3>

@if (question is null)
{
    <p>Loading...</p>
}
else
{
    <div class="card p-3">
        <p><strong>@question.Question</strong></p>

        <div class="answers-grid">
            @foreach (var option in (question.AnswerOptions ?? new List<AnswerOptionDto>()))
            {
                var id = $"q{question.Id}_opt{option.Id}";
                var css = GetOptionClass(option.Id);

                <label class="answer-card @css @(answered ? "disabled" : "")" for="@id">
                    <input type="radio"
                           id="@id"
                           name="answer"
                           value="@option.Id"
                           checked="@(selectedAnswerId == option.Id)"
                           @onchange="() => selectedAnswerId = option.Id"
                           disabled="@answered" />

                    <span class="answer-text">@option.Answer</span>
                </label>
            }
        </div>

        <div style="margin-top:12px;">
            <button class="btn btn-primary"
                    disabled="@(!selectedAnswerId.HasValue || answered)"
                    @onclick="SubmitAnswer">
                Svara
            </button>
            @*  Ändra till div *@
            <button class="btn btn-secondary"
                    style="margin-left:8px;"
                    disabled="@(!answered)"
                    @onclick="NextQuestion">
                Nästa
            </button>
        </div>

        @if (result != null)
        {
            <div class="mt-3">
                @if (result.IsCorrect)
                {
                    <div class="alert alert-success">
                        <p>Rätt svar!</p>
                    </div>
                }
                else
                {
                    <div class="alert alert-danger">
                        <p>Fel svar.</p>
                        <p>Rätt svar var: @GetCorrectAnswerText()</p>
                    </div>
                }
            </div>
        }
    </div>
}

<style>
    .answers-grid {
        display: grid;
        gap: 12px;
        margin-top: 12px;
    }

    .answer-card {
        display: flex;
        align-items: center;
        gap: 12px;
        border: 2px solid #ccc;
        border-radius: 10px;
        padding: 12px 14px;
        background: white;
        cursor: pointer;
        user-select: none;
    }

        .answer-card.selected {
            border-color: #7c3aed;
            background: #f3f0ff;
        }

        .answer-card.correct {
            border-color: #16a34a;
            background: #dcfce7;
        }

        .answer-card.incorrect {
            border-color: #dc2626;
            background: #fee2e2;
        }

        .answer-card.disabled {
            cursor: not-allowed;
            opacity: 0.95;
            pointer-events: none;
        }

    .answer-text {
        font-weight: 600;
    }
</style>

@code {
    [Parameter] public int SubCategoryId { get; set; }

    private QuestionDto? question;
    private int? selectedAnswerId;
    private bool answered;
    private SubmitResponseDto? result;

    protected override async Task OnParametersSetAsync()
    {
        await LoadQuestion();
    }

    private async Task LoadQuestion()
    {
        question = await Api.GetNextQuestionAsync(SubCategoryId);
        selectedAnswerId = null;
        answered = false;
        result = null;
    }

    private async Task SubmitAnswer()
    {
        if (question is null || !selectedAnswerId.HasValue) return;

        var res = await Api.SubmitAnswerWithFeedbackAsync(new SubmitAnswerRequestDto
        {
            SubCategoryId = SubCategoryId,
            QuestionId = question.Id,
            AnswerOptionId = selectedAnswerId.Value
        });

        if (res is null) return;

        result = res;
        answered = true;
    }

    private async Task NextQuestion()
    {
        await LoadQuestion();
    }

    private string GetOptionClass(int optionId)
    {
        if (result is null)
        {
            if (selectedAnswerId.HasValue && selectedAnswerId.Value == optionId)
                return "selected";
            return "";
        }

        if (optionId == result.CorrectAnswerOptionId)
            return "correct";

        if (!result.IsCorrect && selectedAnswerId.HasValue && optionId == selectedAnswerId.Value)
            return "incorrect";

        return "";
    }

    private string GetCorrectAnswerText()
    {
        if (question?.AnswerOptions is null || result is null) return "(okänt)";
        return question.AnswerOptions.FirstOrDefault(o => o.Id == result.CorrectAnswerOptionId)?.Answer ?? "(okänt)";
    }
}



