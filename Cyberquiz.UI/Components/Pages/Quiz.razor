@page "/quiz/{SubCategoryId:int}"
@using Cyberquiz.Shared.DTOs

@using Cyberquiz.UI.Components.Pages.Components
@using Cyberquiz.UI.Services
@using Microsoft.AspNetCore.Authorization
@inject ApiService ApiService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

@attribute [Authorize]

<h3>Quiz</h3>
@if (!string.IsNullOrWhiteSpace(_error))
{
    <pre style="color:red; white-space:pre-wrap;">@_error</pre>
}
else if (_loading)
{
    <p>Laddar...</p>
}
else if (question == null)
{
    <div class="alert alert-info">
        <h4>Quizet är klart ✅</h4>

        @if (_quizResult != null)
        {
            <p>Du fick <strong>@_quizResult.Score</strong> av <strong>@_quizResult.TotalQuestions</strong> rätt.</p>
        }
        else
        {
            <p>Alla frågor är besvarade.</p>
        }

        <button class="btn btn-secondary" @onclick="GoBack">
            Tillbaka till kategorier
        </button>
    </div>
}
else
{
    <div class="card p-3">
        <p><strong>@question.Question</strong></p>

        <div class="answers-grid">
            @foreach (var option in (question.AnswerOptions ?? new List<AnswerOptionDto>()))
            {
                var id = $"q{question.Id}_opt{option.Id}";
                var css = GetOptionClass(option.Id);

                <label class="answer-card @css @(answered ? "disabled" : "")" for="@id">
                    <input type="radio"
                           id="@id"
                           name="answer"
                           value="@option.Id"
                           checked="@(selectedAnswerId == option.Id)"
                           @onchange="() => selectedAnswerId = option.Id"
                           disabled="@answered" />

                    <span class="answer-text">@option.Answer</span>
                </label>
            }
        </div>

        <div style="margin-top:12px;">
            <button class="btn btn-primary"
                    disabled="@(!selectedAnswerId.HasValue || answered)"
                    @onclick="SubmitAnswer">
                Svara
            </button>

            <button class="btn btn-secondary"
                    style="margin-left:8px;"
                    disabled="@(!answered)"
                    @onclick="NextQuestion">
                Nästa
            </button>
        </div>

        @if (result != null)
        {
            <div class="mt-3">
                @if (result.IsCorrect)
                {
                    <div class="alert alert-success">
                        <p>Rätt svar!</p>
                    </div>
                }
                else
                {
                    <div class="alert alert-danger">
                        <p>Fel svar. Rätt svar var: @GetCorrectAnswerText()</p>
                    </div>
                }
            </div>
        }
        <div class="d-flex gap-2 justify-content-center mt-4">
            <button class="btn btn-primary" @onclick="async () => await RestartQuiz()">
                Starta om
            </button>
            <button class="btn btn-secondary" @onclick="GoBack">
                Tillbaka
            </button>
        </div>
    </div>
}

<style>
    .answers-grid {
        display: grid;
        gap: 12px;
        margin-top: 12px;
    }

    .answer-card {
        display: flex;
        align-items: center;
        gap: 12px;
        border: 2px solid #ccc;
        border-radius: 10px;
        padding: 12px 14px;
        background: white;
        cursor: pointer;
        user-select: none;
    }

        .answer-card.selected {
            border-color: #7c3aed;
            background: #f3f0ff;
        }

        .answer-card.correct {
            border-color: #16a34a;
            background: #dcfce7;
        }

        .answer-card.incorrect {
            border-color: #dc2626;
            background: #fee2e2;
        }

        .answer-card.disabled {
            cursor: not-allowed;
            opacity: 0.95;
            pointer-events: none;
        }

    .answer-text {
        font-weight: 600;
    }
</style>

@code {
    [Parameter] public int SubCategoryId { get; set; }

    private QuestionDto? question;
    private int? selectedAnswerId;
    private bool answered;
    private SubmitResponseDto? result;
    private bool _loading;
    private UserProgressDto? _quizResult;
    private string? _error;
    private string? _userName;
    private int _progressId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userName = authState.User.Identity?.Name;
        _progressId = await ApiService.StartSessionAsync(_userName!, SubCategoryId);
        await LoadQuestion();
    }

    private async Task LoadQuestion()
    {
        _loading = true;

        question = await ApiService.GetNextQuestionAsync(SubCategoryId, _progressId);

        if (question == null)
        {
            var progress = await ApiService.GetUserProgressAsync(_userName);
            _quizResult = progress.FirstOrDefault(p => p.Id == _progressId);
        }

        selectedAnswerId = null;
        answered = false;
        result = null;

        _loading = false;
    }

    private async Task SubmitAnswer()
    {
        try
        {
            if (question is null || !selectedAnswerId.HasValue) return;

            var res = await ApiService.SubmitAnswerWithFeedbackAsync(new SubmitAnswerRequestDto
            {
                SubCategoryId = SubCategoryId,
                QuestionId = question.Id,
                AnswerOptionId = selectedAnswerId.Value,
                UserName = _userName,
                ProgressId = _progressId
            });

            if (res is null)
            {
                _error = "API returnerade null.";
                return;
            }

            result = res;
            answered = true;
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
        }
    }

    private async Task NextQuestion()
    {
        await LoadQuestion();
    }
    private async Task RestartQuiz()
    {
        _progressId = await ApiService.StartSessionAsync(_userName!, SubCategoryId);
        await LoadQuestion();
    }

    private string GetOptionClass(int optionId)
    {
        if (result is null)
        {
            if (selectedAnswerId.HasValue && selectedAnswerId.Value == optionId)
                return "selected";
            return "";
        }

        if (optionId == result.CorrectAnswerOptionId)
            return "correct";

        if (!result.IsCorrect && selectedAnswerId.HasValue && optionId == selectedAnswerId.Value)
            return "incorrect";

        return "";
    }

    private string GetCorrectAnswerText()
    {
        if (question?.AnswerOptions is null || result is null) return "(okänt)";
        return question.AnswerOptions.FirstOrDefault(o => o.Id == result.CorrectAnswerOptionId)?.Answer ?? "(okänt)";
    }

    private void GoBack()
    {
        Nav.NavigateTo("/categories");
    }
}



