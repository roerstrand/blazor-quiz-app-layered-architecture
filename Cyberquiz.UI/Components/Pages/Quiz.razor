@page "/quiz/{SubCategoryId:int}"
@using Cyberquiz.Shared.DTOs
@using Microsoft.AspNetCore.Authorization
@inject ApiService ApiService
@inject NavigationManager Nav
@rendermode InteractiveServer
@attribute [Authorize]

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else if (_loading)
{
    <div class="d-flex align-items-center gap-2 text-muted">
        <div class="spinner-border spinner-border-sm"></div>
        <span>Loading question...</span>
    </div>
}
else if (question == null)
{
    <div class="quiz-container">
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <div style="font-size:3rem;" class="mb-3">🎉</div>
                <h2 class="mb-2">Quiz complete!</h2>

                @if (_quizResult != null)
                {
                    var pct = _quizResult.TotalQuestions > 0
                        ? (int)((double)_quizResult.Score / _quizResult.TotalQuestions * 100)
                        : 0;

                    <p class="text-muted mb-3">
                        You got <strong>@_quizResult.Score</strong> of <strong>@_quizResult.TotalQuestions</strong> correct (@pct%)
                    </p>

                    <div class="progress mb-4" style="height:10px;">
                        <div class="progress-bar @(pct >= 80 ? "bg-success" : pct >= 50 ? "bg-warning" : "bg-danger")"
                             style="width:@(pct)%"></div>
                    </div>

                    @if (pct >= 80)
                    {
                        <div class="alert alert-success">✅ Passed! You unlocked the next level.</div>
                    }
                    else
                    {
                        <div class="alert alert-warning">⚠️ You need at least 80% to unlock the next level.</div>
                    }
                }

                <div class="d-flex gap-2 justify-content-center mt-3">
                    <button class="btn btn-primary" @onclick="RestartQuiz">Try again</button>
                    <button class="btn btn-outline-secondary" @onclick="GoBack">Back</button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="quiz-container">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="text-muted small fw-bold">QUESTION</span>
                <button class="btn btn-outline-secondary btn-sm" @onclick="GoBack">Cancel</button>
            </div>
            <div class="card-body p-4">
                <p class="quiz-question">@question.Question</p>

                <div class="answers-grid">
                    @foreach (var option in question.AnswerOptions ?? [])
                    {
                        var optId = option.Id;
                        <label class="answer-card @GetOptionClass(optId) @(answered ? "disabled" : "")">
                            <input type="radio"
                                   name="answer"
                                   value="@optId"
                                   checked="@(selectedAnswerId == optId)"
                                   @onchange="() => selectedAnswerId = optId"
                                   disabled="@answered" />
                            <span class="answer-text">@option.Answer</span>
                        </label>
                    }
                </div>

                @if (result != null)
                {
                    @if (result.IsCorrect)
                    {
                        <div class="alert alert-success py-2 mt-2">✓ Correct!</div>
                    }
                    else
                    {
                        <div class="alert alert-danger py-2 mt-2">
                            ✗ Wrong. Correct answer: <strong>@GetCorrectAnswerText()</strong>
                        </div>
                    }
                }

                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-primary"
                            disabled="@(!selectedAnswerId.HasValue || answered)"
                            @onclick="SubmitAnswer">
                        Submit
                    </button>
                    <button class="btn btn-secondary"
                            disabled="@(!answered)"
                            @onclick="LoadQuestion">
                        Next →
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int SubCategoryId { get; set; }

    private QuestionDto? question;
    private int? selectedAnswerId;
    private bool answered;
    private SubmitResponseDto? result;
    private bool _loading;
    private UserProgressDto? _quizResult;
    private string? _error;
    private int _progressId;

    protected override async Task OnInitializedAsync()
    {
        _progressId = await ApiService.StartSessionAsync(SubCategoryId);
        await LoadQuestion();
    }

    private async Task LoadQuestion()
    {
        _loading = true;
        question = await ApiService.GetNextQuestionAsync(SubCategoryId, _progressId);
        if (question == null)
        {
            var progress = await ApiService.GetUserProgressAsync();
            _quizResult = progress.FirstOrDefault(p => p.Id == _progressId);
        }
        selectedAnswerId = null;
        answered = false;
        result = null;
        _loading = false;
    }

    private async Task SubmitAnswer()
    {
        if (question is null || !selectedAnswerId.HasValue) return;
        try
        {
            result = await ApiService.SubmitAnswerWithFeedbackAsync(new SubmitAnswerRequestDto
            {
                SubCategoryId = SubCategoryId,
                QuestionId = question.Id,
                AnswerOptionId = selectedAnswerId.Value,
                ProgressId = _progressId
            });
            if (result != null) answered = true;
            else _error = "Could not submit answer.";
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task RestartQuiz()
    {
        _progressId = await ApiService.StartSessionAsync(SubCategoryId);
        await LoadQuestion();
    }

    private string GetOptionClass(int optionId)
    {
        if (result is null) return selectedAnswerId == optionId ? "selected" : "";
        if (optionId == result.CorrectAnswerOptionId) return "correct";
        if (!result.IsCorrect && selectedAnswerId == optionId) return "incorrect";
        return "";
    }

    private string GetCorrectAnswerText()
        => question?.AnswerOptions?.FirstOrDefault(o => o.Id == result?.CorrectAnswerOptionId)?.Answer ?? "(unknown)";

    private void GoBack() => Nav.NavigateTo("/categories");
}
