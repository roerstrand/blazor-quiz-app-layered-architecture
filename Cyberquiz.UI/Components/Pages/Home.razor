@page "/"
@layout AuthLayout
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthenticationStateProvider
@rendermode InteractiveServer

<div class="auth-card" style="max-width:480px; text-align:center;">
    <div class="brand-logo-lg" style="margin-bottom:1.75rem;"><span class="brand-hack">Hack</span><span class="brand-proof">Proof</span></div>

    <h1 class="auth-title" style="font-size:1.6rem;">Test your cybersecurity knowledge</h1>
    <p class="auth-subtitle" style="margin-bottom:2rem;">
        Learn about cybersecurity through interactive quizzes and get personal feedback from our AI coach.
    </p>

    <div class="d-flex gap-3" style="justify-content:center;">
        <a href="/Account/Login" class="btn btn-primary btn-lg">Log in</a>
        <a href="/Account/Register" class="btn btn-outline-secondary btn-lg" style="background:#fff; border-color:#4f46e5; color:#4f46e5;">Create account</a>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User?.Identity?.IsAuthenticated == true)
            Nav.NavigateTo("/categories");
    }
}
