@page "/categories/{CategoryId:int}/subcategories"
@using Cyberquiz.Shared.DTOs
@using Microsoft.AspNetCore.Authorization
@inject ApiService ApiService
@inject NavigationManager Nav
@rendermode InteractiveServer
@attribute [Authorize]

<div class="mb-3">
    <button class="btn btn-outline-secondary btn-sm" @onclick="GoBack">← Back to categories</button>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else if (_isLoading)
{
    <div class="d-flex align-items-center gap-2 text-muted">
        <div class="spinner-border spinner-border-sm"></div>
        <span>Loading...</span>
    </div>
}
else
{
    <div class="page-header">
        <h1>@_categoryName</h1>
        <p class="text-muted">Choose a module and start the quiz.</p>
    </div>

    @if (_filteredSubs.Count == 0)
    {
        <div class="alert alert-info">No modules found.</div>
    }
    else
    {
        @foreach (var s in _filteredSubs.OrderBy(x => x.Order))
        {
            var subId = s.Id;
            var isLocked = s.IsLocked;

            <div class="category-card mb-3">
                <div class="category-card-header">
                    <div>
                        <h3>@(s.IsLocked ? "🔒" : s.IsCompleted ? "✅" : "🔓") @s.Name</h3>
                        <small class="text-muted">Level @s.Order &bull; @s.QuestionCount questions</small>
                    </div>
                    <button class="btn btn-sm @(isLocked ? "btn-secondary" : "btn-primary")"
                            disabled="@isLocked"
                            @onclick="() => StartQuiz(subId)">
                        @(isLocked ? "Locked" : "Start quiz")
                    </button>
                </div>
                @if (!string.IsNullOrWhiteSpace(s.Description) || s.IsLocked)
                {
                    <div class="category-card-body">
                        @if (!string.IsNullOrWhiteSpace(s.Description))
                        {
                            <p class="text-muted fst-italic small mb-1">@s.Description</p>
                        }
                        @if (s.IsLocked)
                        {
                            <small class="text-danger">Requires 80% on the previous level.</small>
                        }
                    </div>
                }
            </div>
        }
    }
}

@code {
    [Parameter] public int CategoryId { get; set; }

    private List<SubCategoryDto>? _allSubs;
    private string? _categoryName;
    private string? _error;
    private bool _isLoading = true;

    private List<SubCategoryDto> _filteredSubs =>
        _allSubs?.Where(s => s.CategoryName.Equals(_categoryName, StringComparison.OrdinalIgnoreCase)).ToList() ?? [];

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            var categories = await ApiService.GetCategoriesAsync();
            var cat = categories.FirstOrDefault(c => c.Id == CategoryId);
            if (cat is null) { _error = "Category not found."; return; }
            _categoryName = cat.Name;
            _allSubs = await ApiService.GetSubCategoriesAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _isLoading = false; }
    }

    private void StartQuiz(int subId) => Nav.NavigateTo($"/quiz/{subId}");
    private void GoBack() => Nav.NavigateTo("/categories");
}
