@page "/categories/{CategoryId:int}/subcategories"
@using Cyberquiz.Shared.DTOs
@using Cyberquiz.UI.Services
@using Microsoft.AspNetCore.Authorization
@inject ApiService ApiService
@inject NavigationManager Nav
@rendermode InteractiveServer

@attribute [Authorize]

<h3>Subkategorier</h3>

@if (_subs is null)
{
    <p>Laddar...</p>
}
else if (_subs.Count == 0)
{
    <p>Inga subkategorier.</p>
}
else
{
    @foreach (var s in _subs.OrderBy(x => x.Order))
    {
        <div class="card p-3 mb-3">
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <div>
                    <h5 style="margin:0;">
                        @(s.IsLocked ? "🔒" : "🔓") @s.Name
                        @if (s.IsCompleted)
                        {
                            <span>✅</span>
                        }
                    </h5>

                    <div style="opacity:.8;">
                        <span>Kategori: @s.CategoryName</span>
                        <span style="margin-left:10px;">Nivå: @s.Order</span>
                        <span style="margin-left:10px;">Frågor: @s.QuestionCount</span>
                    </div>
                </div>

                <button class="btn btn-primary"
                        disabled="@s.IsLocked"
                        @onclick="() => StartQuiz(s.Id)">
                    Starta quiz
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(s.Description))
            {
                <p style="margin-top:10px;">@s.Description</p>
            }
        </div>
    }
}

@code {
    [Parameter] public int CategoryId { get; set; }
    private List<SubCategoryDto>? _subs;

    protected override async Task OnParametersSetAsync()
    {
        _subs = await ApiService.GetSubCategoriesByCategoryIdAsync(CategoryId);
    }

    private void StartQuiz(int subCategoryId)
        => Nav.NavigateTo($"/quiz/{subCategoryId}");
}

