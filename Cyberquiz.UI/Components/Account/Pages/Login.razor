@page "/Account/Login"
@layout AuthLayout
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@inject AuthApiService AuthApi
@inject JwtTokenStore TokenStore
@inject JwtAuthStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<div class="auth-card">
    <div class="brand-logo-lg"><span class="brand-hack">Hack</span><span class="brand-proof">Proof</span></div>

    <h1 class="auth-title">Welcome back</h1>
    <p class="auth-subtitle">Log in to continue</p>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger py-2">@errorMessage</div>
    }

    <EditForm Model="Input" OnValidSubmit="LoginUser">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label class="form-label fw-semibold" for="username">Username</label>
            <InputText @bind-Value="Input.UserName" id="username" class="form-control" autocomplete="username" placeholder="Enter username" />
            <ValidationMessage For="() => Input.UserName" class="text-danger small" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold" for="password">Password</label>
            <InputText type="password" @bind-Value="Input.Password" id="password" class="form-control" autocomplete="current-password" placeholder="Enter password" />
            <ValidationMessage For="() => Input.Password" class="text-danger small" />
        </div>

        <button type="submit" class="btn btn-primary w-100 mt-1" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            Log in
        </button>
    </EditForm>

    <p class="text-center mt-3 small text-muted">
        No account? <a href="/Account/Register">Register here</a>
    </p>
</div>

@code {
    private string? errorMessage;
    private bool isLoading;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private InputModel Input { get; set; } = new();

    public async Task LoginUser()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var (response, error) = await AuthApi.LoginAsync(Input.UserName, Input.Password);

            if (response != null)
            {
                TokenStore.Set(response.Token, response.Username);
                AuthStateProvider.NotifyAuthStateChanged();
                NavigationManager.NavigateTo(ReturnUrl ?? "/categories");
            }
            else
            {
                errorMessage = error ?? "Login failed.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }

        isLoading = false;
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Username is required.")]
        public string UserName { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";
    }
}
