@page "/Account/Register"
@layout AuthLayout
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@inject AuthApiService AuthApi
@inject JwtTokenStore TokenStore
@inject JwtAuthStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<div class="auth-card">
    <div class="brand-logo-lg"><span class="brand-hack">Hack</span><span class="brand-proof">Proof</span></div>

    <h1 class="auth-title">Create account</h1>
    <p class="auth-subtitle">Get started with HackProof</p>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger py-2">@errorMessage</div>
    }

    <EditForm Model="Input" OnValidSubmit="RegisterUser">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label class="form-label fw-semibold" for="username">Username</label>
            <InputText @bind-Value="Input.UserName" id="username" class="form-control" autocomplete="username" placeholder="Choose a username" />
            <ValidationMessage For="() => Input.UserName" class="text-danger small" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold" for="password">Password</label>
            <InputText type="password" @bind-Value="Input.Password" id="password" class="form-control" autocomplete="new-password" placeholder="At least 6 characters" />
            <ValidationMessage For="() => Input.Password" class="text-danger small" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold" for="confirm">Confirm password</label>
            <InputText type="password" @bind-Value="Input.ConfirmPassword" id="confirm" class="form-control" autocomplete="new-password" placeholder="Repeat password" />
            <ValidationMessage For="() => Input.ConfirmPassword" class="text-danger small" />
        </div>

        <button type="submit" class="btn btn-primary w-100 mt-1" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            Create account
        </button>
    </EditForm>

    <p class="text-center mt-3 small text-muted">
        Already have an account? <a href="/Account/Login">Log in</a>
    </p>
</div>

@code {
    private string? errorMessage;
    private bool isLoading;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private InputModel Input { get; set; } = new();

    public async Task RegisterUser()
    {
        isLoading = true;
        errorMessage = null;

        var (response, error) = await AuthApi.RegisterAsync(Input.UserName, Input.Password);

        if (response != null)
        {
            TokenStore.Set(response.Token, response.Username);
            AuthStateProvider.NotifyAuthStateChanged();
            NavigationManager.NavigateTo(ReturnUrl ?? "/categories");
        }
        else
        {
            errorMessage = error ?? "Registration failed.";
        }

        isLoading = false;
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Username is required.")]
        public string UserName { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [StringLength(100, ErrorMessage = "Password must be at least {2} characters.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [DataType(DataType.Password)]
        [Compare("Password", ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
